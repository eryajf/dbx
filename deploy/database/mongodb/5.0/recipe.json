{
  "database": "mongodb",
  "name": "MongoDB",
  "version": "5.0.5",
  "displayVersion": "5.0",
  "image": "docker.cnb.cool/znb/images/mongo:5.0.5",
  "platforms": ["linux/amd64", "linux/arm64"],
  "service": "database",
  "defaultPort": 27017,
  "connection": { "host": "127.0.0.1", "port": 27018, "username": "root", "password": "123456", "database": "dbx", "authSource": "admin" },
  "shell": ["mongosh", "--quiet", "mongodb://root:${DB_PASSWORD}@127.0.0.1:27017/dbx?authSource=admin"],
  "smoke": { "steps": [{ "name": "query initialized document over TCP", "command": ["mongosh", "--quiet", "mongodb://root:${DB_PASSWORD}@127.0.0.1:27017/dbx?authSource=admin", "--eval", "db.dbx_smoke.findOne({_id: 1}).note"], "expect": "DBX smoke" }] }
}
